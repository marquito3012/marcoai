# Marco AI Environment Configuration
# Copy to .env and fill in your API keys

# Debug mode (set to false for production)
DEBUG=false
LOG_LEVEL=WARNING

# Data directory (SQLite database location)
DATA_DIR=./data

# LLM API Keys (at least one required)
# Groq (fastest, recommended first choice)
GROQ_API_KEY=

# OpenRouter (fallback)
OPENROUTER_API_KEY=

# Google Gemini (alternative fallback)
GEMINI_API_KEY=

# Google OAuth (for Calendar/Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Memory limits (Raspberry Pi 3 optimization)
MAX_MEMORY_MB=512
SQLITE_CACHE_SIZE=2000

# Cloudflare Tunnel (for remote access without port forwarding)
# Get your token from: https://one.dash.cloudflare.com/
CLOUDFLARE_TUNNEL_TOKEN=
# Your public URL via Cloudflare (informational, not loaded by app)
# CLOUDFLARE_TUNNEL_URL=https://your-subdomain.your-domain.com
