# Configuración de Google OAuth y APIs (Obligatorio)
GOOGLE_CLIENT_ID=tu_cliente_id_de_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_cliente_secret_de_google

# Configuración de Groq API (Obligatorio)
GROQ_API_KEY=gsk_tu_clave_api_de_groq

# Seguridad del Backend
# Generar una con: openssl rand -hex 32
SECRET_KEY=clave_secreta_super_segura_para_firmar_jwts

# Base de Datos
DATABASE_URL=sqlite:///./marcoai.db

# Configuración de Cloudflare Tunnel (Opcional para local, obligatorio para prod)
# CLOUDFLARE_TUNNEL_TOKEN=ey...

# CORS (Dominios permitidos)
# En producción, usa tu dominio de Cloudflare, ej: https://marco.tudominio.com
FRONTEND_URL=http://localhost:3000
